# Database
# SQLite (default, no extra setup needed)
DB_URL=sqlite://~/.mnemo/memory.db
# PostgreSQL (for vector search)
# DB_URL=postgres://postgres:postgres@localhost:5432/mnemo

# Embedding (OpenAI Compatible)
# Works with Ollama, LM Studio, OpenAI, LocalAI, etc.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSIONS=768

# Server Transport
# Options: stdio | sse | both (default: both)
TRANSPORT=both
SSE_PORT=8765

# Host identification (default: auto-detected via os.Hostname())
# Override for Docker containers to maintain memory continuity
HOST_ID=
